{
  "manifest_version": 3,
  "name": "Journal Downloader",
  "description": "Batch download PDFs from journal TOC pages. Enhanced parsers for NEJM, Nature, Science. Generic PDF detection fallback.",
  "version": "3.1",
  "permissions": ["downloads", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png"
  }
}
