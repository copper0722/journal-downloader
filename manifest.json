{
  "manifest_version": 3,
  "name": "Journal Downloader",
  "description": "Export journal TOC metadata and batch-download only explicitly open-access/free PDFs. Non-OA and subscription items are metadata-only.",
  "version": "3.22.1",
  "permissions": ["downloads", "activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png"
  }
}
